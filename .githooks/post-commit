#!/usr/bin/env bash
set -euo pipefail

if [[ "${MDDB_SKIP_POST_COMMIT_DEPLOY:-0}" == "1" ]]; then
  echo "post-commit: MDDB_SKIP_POST_COMMIT_DEPLOY=1, skipping deploy"
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "${repo_root}"

echo "post-commit: running CI/CD deploy flow"
npm run deploy
