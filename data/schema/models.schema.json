{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mddb.dev/schemas/models.schema.json",
  "title": "mddb models.json",
  "description": "Maintainer-controlled model facts. Pricing and endpoint availability belong in provider files.",
  "type": "object",
  "required": ["schema_version", "models"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "models": {
      "type": "array",
      "items": { "$ref": "#/$defs/model" },
      "uniqueItems": true
    },
    "last_updated": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "dateLike": {
      "type": "string",
      "description": "ISO date or date-time; allow YYYY-MM when upstream only gives month precision.",
      "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?(T.*Z)?$"
    },
    "modalities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["text", "image", "audio", "video", "embedding", "file", "tool", "json", "other"]
      },
      "uniqueItems": true
    },
    "model": {
      "type": "object",
      "required": ["id", "model", "author"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/slug",
          "description": "URL/API-friendly model id. Does not include author/provider namespace."
        },
        "model": {
          "type": "string",
          "description": "Official/display model name."
        },
        "alias": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "default": []
        },
        "author": {
          "$ref": "#/$defs/slug",
          "description": "研发方 provider id; must resolve to a provider entry."
        },
        "input_modalities": { "$ref": "#/$defs/modalities" },
        "output_modalities": { "$ref": "#/$defs/modalities" },
        "reasoning": { "type": "boolean" },
        "tool_calling": { "type": "boolean" },
        "context_length": { "type": "integer", "minimum": 0 },
        "max_input_tokens": { "type": "integer", "minimum": 0 },
        "max_output_tokens": { "type": "integer", "minimum": 0 },
        "released": { "$ref": "#/$defs/dateLike" },
        "deprecation": { "$ref": "#/$defs/dateLike" },
        "other_parameters": {
          "type": "object",
          "description": "Unmapped non-provider source fields preserved as key/value facts.",
          "additionalProperties": true,
          "default": {}
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" },
          "default": []
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "required": ["source", "source_id"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "source_id": { "type": "string" },
        "url": { "type": "string" },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
